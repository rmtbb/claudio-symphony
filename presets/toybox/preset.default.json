{
  "name": "toybox",
  "description": "Playful and bright. A major pentatonic. Toy piano, glockenspiel, soft wood block, hand-bell. Tasteful delay on the toy piano gives a music-box-winding-down feel.",
  "drone": null,
  "master_gain": 0.48,
  "drone_gain": 0.0,
  "phrase_roots": [9, 4],
  "scale_pitches": [69, 71, 73, 76, 78, 81, 83, 85, 88, 90],
  "voices": {
    "toy_piano": { "dir": "toy_piano", "mioi": 0.25, "gain": 0.42, "rate_jitter": true },
    "glock": { "dir": "glock", "mioi": 0.4, "gain": 0.32 },
    "block": { "dir": "block", "mioi": 0.05, "gain": 0.50, "rate_jitter": true, "tonal_anchor_midi": 76 },
    "hand_bell": { "dir": "hand_bell", "mioi": 8.0, "gain": 0.38 }
  },
  "events": {
    "PreToolUse":       { "default": "block" },
    "PostToolUse":      { "default": "toy_piano", "on_failure": "glock" },
    "Stop":             { "default": "hand_bell" },
    "SessionStart":     { "default": "hand_bell" },
    "SessionEnd":       { "default": "hand_bell" },
    "SubagentStop":     { "default": "glock" },
    "UserPromptSubmit": { "default": "block" },
    "Notification":     { "default": "glock" },
    "PreCompact":       { "default": "hand_bell" }
  }
}
