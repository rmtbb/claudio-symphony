{
  "name": "paper",
  "description": "Micro-tactile minimal. A major pentatonic. Tiny taps, music-box notes, soft clicks. Almost no reverb, light delay for space. The quietest preset by design.",
  "drone": null,
  "master_gain": 0.42,
  "drone_gain": 0.0,
  "phrase_roots": [9, 4],
  "scale_pitches": [69, 71, 73, 76, 78, 81, 83, 85, 88, 90, 93],
  "voices": {
    "music_box": { "dir": "music_box", "mioi": 0.30, "gain": 0.40, "rate_jitter": true },
    "tap": { "dir": "tap", "mioi": 0.05, "gain": 0.40, "rate_jitter": true, "tonal_anchor_midi": 81 },
    "click": { "dir": "click", "mioi": 0.05, "gain": 0.30 },
    "single_chime": { "dir": "single_chime", "mioi": 0.6, "gain": 0.32 }
  },
  "events": {
    "PreToolUse":       { "default": "click" },
    "PostToolUse":      { "default": "music_box", "on_failure": "single_chime" },
    "Stop":             { "default": "single_chime" },
    "SessionStart":     { "default": "single_chime" },
    "SessionEnd":       { "default": "single_chime" },
    "SubagentStop":     { "default": "single_chime" },
    "UserPromptSubmit": { "default": "tap" },
    "Notification":     { "default": "single_chime" },
    "PreCompact":       { "default": "music_box" }
  }
}
